# =====================================================================
# Drona Valley Public School — Environment Variables
# Copy this file to .env.local for local development, and add the same
# keys in the Vercel dashboard (Project → Settings → Environment Variables)
# for production.
#
# Both forms send through the SAME noreply@eldenheights.org SMTP account,
# but the delivered-to address differs:
#   - Registration → admission@eldenheights.org
#   - Contact      → vsp.contact@eldenheights.org
#
# Each email already sets replyTo to the visitor's address, so hitting
# "Reply" in your inbox will reply directly to the parent.
# =====================================================================

# Public site URL (used for canonical URLs, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://vsp.eldenheights.org

# ---------------------------------------------------------------------
# FORM 1 — ADMISSIONS / REGISTRATION  (the "Register your child" form)
# Sent from noreply@eldenheights.org, delivered to admission@eldenheights.org
# ---------------------------------------------------------------------
REG_SMTP_HOST=smtp.your-provider.com
REG_SMTP_PORT=465
# "true" for port 465 (SSL), "false" for port 587 (STARTTLS)
REG_SMTP_SECURE=true
REG_SMTP_USER=noreply@eldenheights.org
REG_SMTP_PASS=your-noreply-smtp-password
REG_FROM_EMAIL=noreply@eldenheights.org
REG_TO_EMAIL=admission@eldenheights.org

# ---------------------------------------------------------------------
# FORM 2 — GENERAL CONTACT  (the "Say hello / general enquiry" form)
# Sent from noreply@eldenheights.org, delivered to vsp.contact@eldenheights.org
# ---------------------------------------------------------------------
CONTACT_SMTP_HOST=smtp.your-provider.com
CONTACT_SMTP_PORT=465
CONTACT_SMTP_SECURE=true
CONTACT_SMTP_USER=noreply@eldenheights.org
CONTACT_SMTP_PASS=your-noreply-smtp-password
CONTACT_FROM_EMAIL=noreply@eldenheights.org
CONTACT_TO_EMAIL=vsp.contact@eldenheights.org
