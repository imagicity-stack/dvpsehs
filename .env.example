# =====================================================================
# Drona Valley Public School — Environment Variables
# Copy this file to .env.local for local development, and add the same
# keys in the Vercel dashboard (Project → Settings → Environment Variables)
# for production.
#
# IMPORTANT: The two website forms intentionally use TWO SEPARATE SMTP
# mailboxes so that Admissions/Registration enquiries and general
# Contact messages can be routed to different inboxes / providers.
# =====================================================================

# Public site URL (used for canonical URLs, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://vsp.eldenheights.org

# ---------------------------------------------------------------------
# FORM 1 — ADMISSIONS / REGISTRATION  (the "Register your child" form)
# Routes to the Admissions inbox.
# ---------------------------------------------------------------------
REG_SMTP_HOST=smtp.your-provider.com
REG_SMTP_PORT=587
# "true" for port 465 (SSL), "false" for port 587 (STARTTLS)
REG_SMTP_SECURE=false
REG_SMTP_USER=admission@eldenheights.org
REG_SMTP_PASS=your-admissions-smtp-password
# The "from" address shown on the email (often must match REG_SMTP_USER)
REG_FROM_EMAIL=admission@eldenheights.org
# Where registration enquiries are delivered (the school admissions desk)
REG_TO_EMAIL=admission@eldenheights.org

# ---------------------------------------------------------------------
# FORM 2 — GENERAL CONTACT  (the "Say hello / general enquiry" form)
# Routes to the front-office / reception inbox.
# ---------------------------------------------------------------------
CONTACT_SMTP_HOST=smtp.your-provider.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_SECURE=false
CONTACT_SMTP_USER=hello@eldenheights.org
CONTACT_SMTP_PASS=your-contact-smtp-password
CONTACT_FROM_EMAIL=hello@eldenheights.org
CONTACT_TO_EMAIL=hello@eldenheights.org
